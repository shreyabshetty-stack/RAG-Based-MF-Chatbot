# Groq API Key for Response Generation
GROQ_API_KEY=your_groq_api_key_here

# Local Persistent Database Configurations
CHROMA_DB_PATH=data/chroma_db
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# Groq Free Tier Rate Limits (for reference and monitoring)
# Do not exceed these limits to avoid HTTP 429 errors
GROQ_REQUESTS_PER_MINUTE=30
GROQ_REQUESTS_PER_DAY=1000
GROQ_TOKENS_PER_MINUTE=12000
GROQ_TOKENS_PER_DAY=100000

# Retry Configuration (for rate limit backoff)
GROQ_MAX_RETRIES=3
GROQ_RETRY_BASE_DELAY_SECS=2
